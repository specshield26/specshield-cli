{
  "name": "specshield",
  "version": "1.0.7",
  "description": "CLI to compare OpenAPI/Swagger specs and detect breaking changes for CI/CD pipelines and local developer workflows.",
  "main": "src/cli.js",
  "bin": {
    "specshield": "./bin/specshield.js"
  },
  "scripts": {
    "start": "node bin/specshield.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .js"
  },
  "keywords": [
    "openapi",
    "swagger",
    "openapi-diff",
    "swagger-diff",
    "api-diff",
    "api-breaking-changes",
    "breaking-change-detection",
    "contract-testing",
    "api-contract",
    "api-versioning",
    "api-governance",
    "ci-cd",
    "devops",
    "github-actions",
    "automation",
    "cli",
    "developer-tools",
    "yaml",
    "json",
    "schema-diff",
    "rest-api",
    "openapi-cli"
  ],
  "license": "MIT",
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "axios": "^1.6.7",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
