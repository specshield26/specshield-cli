{
  "name": "specshield",
  "version": "1.0.12",
  "description": "CLI to compare OpenAPI/Swagger specs and detect breaking changes for CI/CD pipelines and local developer workflows.",
  "main": "src/cli.js",
  "bin": {
    "specshield": "./bin/specshield.js"
  },
  "scripts": {
    "start": "node bin/specshield.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .js"
  },
  "keywords": [
  "openapi",
  "swagger",
  "api-diff",
  "openapi-diff",
  "swagger-diff",
  "api-diff-tool",
  "breaking-change-detection",
  "api-breaking-changes",
  "prevent-breaking-api",
  "api-regression",
  "api-compatibility",
  "contract-testing",
  "consumer-driven-contract",
  "api-contract",
  "contract-verification",
  "can-i-deploy",
  "ci-cd",
  "devops",
  "github-actions",
  "cli",
  "developer-tools",
  "openapi-compare",
  "swagger-compare",
  "pact-alternative",
  "api-contract-testing",
  "microservices",
  "api-quality",
  "api-governance",
  "yaml",
  "json"
],
  "license": "MIT",
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "axios": "^1.6.7",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "js-yaml": "^4.1.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
